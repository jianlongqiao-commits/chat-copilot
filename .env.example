# ── 把天聊下去 · 环境配置模板 ──────────────────────────
# 复制本文件为 .env，然后填入你的实际值
#   cp .env.example .env

# LLM API Key（必填）
# OpenRouter: https://openrouter.ai/keys 获取
# 302.AI 或其他 OpenAI 兼容服务也行，改下面的 endpoint 即可
LLM_API_KEY=sk-your-api-key-here

# LLM API 地址
# OpenRouter（默认）: https://openrouter.ai/api/v1/chat/completions
# 302.AI: https://api.302.ai/v1/chat/completions
# OpenAI 官方: https://api.openai.com/v1/chat/completions
LLM_ENDPOINT=https://openrouter.ai/api/v1/chat/completions

# 模型选择
# 推荐: openai/gpt-4o-mini（便宜快速）
# 高质量: openai/gpt-4o
# 便宜: deepseek/deepseek-chat
LLM_MODEL=openai/gpt-4o-mini

# ── 火山引擎 ASR（豆包语音识别大模型 Seed-ASR 2.0）────────
# 从火山引擎控制台获取: https://console.volcengine.com/speech/app
ASR_APP_ID=your-app-id-here
ASR_ACCESS_TOKEN=your-access-token-here
